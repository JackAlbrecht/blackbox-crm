# Copy to .env.local and fill in values from your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service-role key. Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Optional — only needed if you want the "Send campaign" button to actually send email.
# Create a key at https://resend.com after verifying your sending domain.
RESEND_API_KEY=
